<Window x:Class="monaka_wm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:monaka_wm"
        xmlns:viewmodels="clr-namespace:monaka_wm.ViewModels"
        mc:Ignorable="d"
        Title="monaka-wm" Height="4" Width="1920"
        WindowStyle="None" ResizeMode="NoResize" Topmost="True"
        AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI, Inter, Arial"
        Loaded="Window_Loaded" Closed="Window_Closed"
        MouseEnter="Window_MouseEnter" MouseLeave="Window_MouseLeave">

    <Window.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Burger Menu Style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#F4F4F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3F3F46"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#52525B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Button Style (Float/Tile) -->
        <Style x:Key="ToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#27272A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3F3F46"/>
                                <Setter Property="Foreground" Value="#F4F4F5"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#0284C7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small Arrow Buttons Style inside Tab -->
        <Style x:Key="ArrowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3F3F46"/>
                                <Setter Property="Foreground" Value="#F4F4F5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#3F3F46"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Left/Up Arrow Button Style -->
        <Style x:Key="LeftArrowButtonStyle" TargetType="Button" BasedOn="{StaticResource ArrowButtonStyle}">
            <Setter Property="Content" Value="◀"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsVerticalSplit, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Content" Value="▲"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Right/Down Arrow Button Style -->
        <Style x:Key="RightArrowButtonStyle" TargetType="Button" BasedOn="{StaticResource ArrowButtonStyle}">
            <Setter Property="Content" Value="▶"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsVerticalSplit, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Content" Value="▼"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Dark themed ContextMenu Style for Tabs -->
        <Style x:Key="TabContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#27272A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <EventSetter Event="Opened" Handler="TabContextMenu_Opened"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="2">
                            <ItemsPresenter KeyboardNavigation.TabNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark themed MenuItem Style for Tabs -->
        <Style x:Key="TabMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Checkmark -->
                                <Path x:Name="CheckMark" Grid.Column="0" Data="M 1,4 L 4,7 L 9,2" Stroke="#0EA5E9" StrokeThickness="2" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#27272A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#52525B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Item Style -->
        <Style x:Key="TabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="#202023"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu Style="{StaticResource TabContextMenuStyle}"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="10,4,6,4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                CornerRadius="4,4,0,0" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#F4F4F5"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActiveInColumn}" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#09090B"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#0EA5E9"/>
                                <Setter Property="Foreground" Value="#0EA5E9"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <!-- Top border sensor bar -->
        <Border x:Name="SensorBar" Height="4" VerticalAlignment="Top" Background="#0EA5E9" Opacity="0.5" IsHitTestVisible="False"/>

        <!-- Main Taskbar panel, offset by 4px from the top sensor -->
        <Grid x:Name="MainContentGrid" Background="#18181B" Margin="0,4,0,0" Visibility="Collapsed">
            <!-- 1. Columns Grid (Spans the entire screen width to align split line exactly) -->
            <Grid x:Name="ColumnsGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <!-- Column 0 -->
                    <ColumnDefinition x:Name="Column0Definition" Width="*"/>
                    <!-- Splitter 0 Column -->
                    <ColumnDefinition x:Name="Splitter0Definition" Width="Auto"/>
                    <!-- Column 1 -->
                    <ColumnDefinition x:Name="Column1Definition" Width="0"/>
                    <!-- Splitter 1 Column -->
                    <ColumnDefinition x:Name="Splitter1Definition" Width="Auto"/>
                    <!-- Column 2 -->
                    <ColumnDefinition x:Name="Column2Definition" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- Column 0 List (Left margin set to 200 to prevent overlap with Left Control Panel) -->
                <ListBox Grid.Column="0" x:Name="Column0ListBox" 
                          ItemsSource="{Binding Column0Windows}" 
                          ItemContainerStyle="{StaticResource TabItemStyle}"
                          Margin="200,0,10,0"
                          Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled" SelectionChanged="TabListBox_SelectionChanged"
                          PreviewMouseWheel="TabListBox_PreviewMouseWheel">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Process Icon Placeholder or Title -->
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="0,0,10,0" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                
                                <!-- Arrow Controls -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,2,0">
                                    <Button Style="{StaticResource LeftArrowButtonStyle}" Click="ArrowButton_Click"/>
                                    <Button Click="ArrowButton_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource RightArrowButtonStyle}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.IsTileMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                            <Condition Binding="{Binding CanMoveRight}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Column Separator 0 -->
                <Border Grid.Column="1" x:Name="Splitter0Control" Width="1" Background="#27272A"
                        HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,4"/>

                <!-- Column 1 List -->
                <ListBox Grid.Column="2" x:Name="Column1ListBox" 
                          ItemsSource="{Binding Column1Windows}" 
                          ItemContainerStyle="{StaticResource TabItemStyle}"
                          Margin="10,0,10,0"
                          Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled" SelectionChanged="TabListBox_SelectionChanged"
                          PreviewMouseWheel="TabListBox_PreviewMouseWheel">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="0,0,10,0" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,2,0">
                                    <Button Click="ArrowButton_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LeftArrowButtonStyle}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.IsTileMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                            <Condition Binding="{Binding CanMoveLeft}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Click="ArrowButton_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource RightArrowButtonStyle}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.IsTileMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                            <Condition Binding="{Binding CanMoveRight}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Column Separator 1 -->
                <Border Grid.Column="3" x:Name="Splitter1Control" Width="1" Background="#27272A"
                        HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,4"/>

                <!-- Column 2 List (Right margin set to 100 to prevent overlap with Right Action Panel) -->
                <ListBox Grid.Column="4" x:Name="Column2ListBox" 
                          ItemsSource="{Binding Column2Windows}" 
                          ItemContainerStyle="{StaticResource TabItemStyle}"
                          Margin="10,0,100,0"
                          Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled" SelectionChanged="TabListBox_SelectionChanged"
                          PreviewMouseWheel="TabListBox_PreviewMouseWheel">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="0,0,10,0" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,2,0">
                                    <Button Click="ArrowButton_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LeftArrowButtonStyle}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.IsTileMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                            <Condition Binding="{Binding CanMoveLeft}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Style="{StaticResource RightArrowButtonStyle}" Click="ArrowButton_Click" IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- 2. Overlay: Left Control Panel -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Stretch" Orientation="Horizontal" Margin="8,0" Background="#18181B">
                <!-- Burger Menu Button -->
                <Button Style="{StaticResource IconButtonStyle}" ToolTip="Menu" Click="BurgerMenu_Click">
                    <Button.ContextMenu>
                        <ContextMenu Background="#18181B" Foreground="#F4F4F5" BorderBrush="#27272A">
                            <MenuItem Header="本アプリの終了" Click="ExitMenu_Click" Background="Transparent" Foreground="#F4F4F5"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <TextBlock Text="≡" FontSize="18" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                </Button>

                <!-- Float/Tile Mode Toggle -->
                <ToggleButton Style="{StaticResource ToggleButtonStyle}" 
                               IsChecked="{Binding IsTileMode}" 
                               Margin="6,0,0,0" Content="Float/Tile"/>

                <!-- Vertical/Horizontal split mode toggle -->
                <ToggleButton Style="{StaticResource ToggleButtonStyle}" 
                              IsChecked="{Binding IsVerticalSplit}" 
                              Margin="8,0" 
                              Content="Vert/Horiz"
                              ToolTip="Toggle Split Direction (Horizontal/Vertical)"/>
                
                <!-- Visual Divider -->
                <Border Background="#27272A" Width="1" VerticalAlignment="Stretch" Margin="0,4"/>
            </StackPanel>

            <!-- 3. Overlay: Right Action Panel -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Stretch" Orientation="Horizontal" Margin="8,0" Background="#18181B">
                <!-- End Split Button -->
                <Button Style="{StaticResource IconButtonStyle}" 
                        Command="{Binding EndSplitCommand}"
                        x:Name="EndSplitButton"
                        ToolTip="End screen split and restore to single column" 
                        Margin="0,0,4,0">
                    <TextBlock Text="[End Split]" Foreground="#EF4444" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
